---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ContactModal from '../components/ContactModal.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  currentPage?: 'home' | 'blog' | 'about';
}

const {
  title = 'B·Sides Studio — small studio. big ideas.',
  description = 'A tiny Portland-based studio making iOS apps and games. Skein, Latchkey, Wether — all in progress.',
  ogImage = '/images/b-side-studios-cassette-large.png',
  currentPage,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://bsidesstudio.com').toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(ogImage, Astro.site ?? 'https://bsidesstudio.com').toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site ?? 'https://bsidesstudio.com').toString()} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
      rel="icon"
      href="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 10'><rect width='16' height='10' fill='%231a1612'/><rect x='2' y='2' width='12' height='3' fill='%23efe7d4'/><circle cx='5' cy='7' r='1.5' fill='%23efe7d4'/><circle cx='11' cy='7' r='1.5' fill='%23efe7d4'/></svg>"
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <div class="page-shell">
      <Nav currentPage={currentPage} />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
    <ContactModal />
  </body>
</html>
