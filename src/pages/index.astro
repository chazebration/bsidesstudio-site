---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CassetteCard from '../components/CassetteCard.astro';
import Newsletter from '../components/Newsletter.astro';
import { GAMES } from '../data/games';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const topPosts = allPosts.slice(0, 3);

const formatDate = (d: Date) => {
  const mm = String(d.getUTCMonth() + 1).padStart(2, '0');
  const dd = String(d.getUTCDate()).padStart(2, '0');
  const yy = String(d.getUTCFullYear()).slice(2);
  return `${mm} · ${dd} · ${yy}`;
};
---

<BaseLayout currentPage="home">
  <div class="hero-zine">
    <div class="tape-strip" style="top: 10px; left: -20px; width: 160px; height: 22px; transform: rotate(-4deg);"></div>
    <div class="tape-strip" style="top: 40px; right: 40px; width: 110px; height: 18px; transform: rotate(6deg);"></div>
    <div class="rubber-stamp" style="position: absolute; top: 210px; right: 60px; transform: rotate(9deg);">SIDE B</div>

    <h1 class="hero-tagline">
      small studio.<br/>
      <span class="mark">big ideas.</span>{' '}
      making <span class="underline">apps</span>,<br/>
      games, &amp; whatever sounds fun.
    </h1>
    <p class="hero-sub">
      B·Sides Studio is a tiny Portland studio making iOS apps and games. Everything here is under construction — that's kind of the point.
    </p>

    <div style="margin-top: 28px; display: flex; gap: 12px; flex-wrap: wrap;">
      <a href="#workbench" class="btn alt">▶ SEE THE WORKBENCH</a>
      <a href="mailto:hello@bsidesstudio.com" class="btn ghost js-contact-open">✉ SAY HI</a>
    </div>

    <div style="position: absolute; top: 12px; right: 0; font-family: var(--fs-mono); font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--ink-2);">
      REC ● 00:04:28 / C·90
    </div>
  </div>

  <div id="workbench" class="section-header">
    <span class="sticker">01</span>
    <h2>NOW PLAYING</h2>
    <span class="meta">— on our workbench</span>
  </div>

  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(380px, 1fr)); gap: 32px; padding: 24px 0 60px;">
    {GAMES.map((g, i) => <CassetteCard game={g} index={i} />)}
  </div>

  <div class="section-header">
    <span class="sticker">02</span>
    <h2>LATEST FROM THE BLOG</h2>
    <span class="meta">— fresh from the typewriter</span>
  </div>

  {topPosts.length === 0 ? (
    <p style="font-family: var(--fs-mono); color: var(--ink-2); padding: 20px 0;">
      First post coming soon. Stay tuned.
    </p>
  ) : (
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 24px; padding-bottom: 20px;">
      {topPosts.map((p, i) => (
        <a
          href={`/blog/${p.id}`}
          class="blog-card"
          style={`background: var(--paper-2); padding: 18px; border: 1px solid var(--ink-2); box-shadow: 3px 3px 0 var(--ink-2); transform: rotate(${(i - 1) * 0.6}deg); display: block;`}
        >
          <div style="font-family: var(--fs-mono); font-size: 10px; text-transform: uppercase; letter-spacing: 2px; color: var(--accent-1);">
            {formatDate(p.data.date)} · {p.data.author}
          </div>
          <h3 style="font-family: var(--fs-display); font-size: 15px; margin: 8px 0 10px; line-height: 1.35;">{p.data.title}</h3>
          <p style="font-size: 13px; color: var(--ink-2); margin: 0; line-height: 1.5;">{p.data.excerpt.slice(0, 110)}…</p>
        </a>
      ))}
    </div>
  )}

  <div class="section-header">
    <span class="sticker">03</span>
    <h2>MAIL IT IN</h2>
    <span class="meta">— new posts, occasional updates</span>
  </div>
  <Newsletter />
</BaseLayout>
